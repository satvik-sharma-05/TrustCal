{
  "name": "trustcal",
  "version": "1.0.0",
  "description": "Identity risk scoring system with MongoDB Atlas",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "train:ml": "cd server/ml/python && python train.py",
    "ml:server": "cd server/ml/python && python model_server.py"
  },
  "keywords": [
    "risk-scoring",
    "identity",
    "security",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "axios": "^1.6.2",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
