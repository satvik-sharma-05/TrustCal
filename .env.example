# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/trustcal?retryWrites=true&w=majority

# Server Configuration
BACKEND_PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# TrustCal ML (required for evaluation)
ML_SERVER_URL=http://127.0.0.1:5001

# Decision thresholds (risk score 0-100). Configurable; not hardcoded.
ALLOW_MAX=30
MFA_MAX=70
